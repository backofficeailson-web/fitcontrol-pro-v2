FLASK_APP=wsgi.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-this-to-a-very-long-random-secret-key
WTF_CSRF_SECRET_KEY=change-this-to-another-long-random-secret-key
# Local universal SQLite path. Works on Windows/Linux because config.py resolves it from project root.
DATABASE_URL=sqlite:///instance/fitcontrol.db
# Production example:
# DATABASE_URL=postgresql+psycopg://fitcontrol:fitcontrol@db:5432/fitcontrol
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_SAMESITE=Lax
MAX_CONTENT_LENGTH=16777216
RATELIMIT_DEFAULT=200 per hour
RATELIMIT_STORAGE_URI=memory://
# Production with Redis:
# REDIS_URL=redis://redis:6379/0
LOG_LEVEL=INFO
JSON_LOGS=False
SECURITY_HEADERS_ENABLED=True
FORCE_HTTPS=False
