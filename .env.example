# =============================================================================
# FitControl Pro 2.0 — Development environment example
# Copy to .env and adjust values for your local machine.
# =============================================================================

FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1

# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-secret-key-change-me-in-production-please
WTF_CSRF_SECRET_KEY=another-long-random-csrf-secret-key

# Local dev DB (SQLite) — for production use PostgreSQL via DATABASE_URL
DATABASE_URL=sqlite:///instance/fitcontrol.db

# Cookies / session
SESSION_COOKIE_SECURE=False
PERMANENT_SESSION_LIFETIME=28800

# Uploads
MAX_CONTENT_LENGTH=16777216

# Rate limit
RATELIMIT_DEFAULT=200 per hour
RATELIMIT_STORAGE_URI=memory://

# Logging
LOG_LEVEL=DEBUG
LOG_TO_STDOUT=False

# Reverse proxy: keep False in local dev
BEHIND_PROXY=False

# Server (used by `python app.py`)
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
