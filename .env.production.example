# =============================================================================
# FitControl Pro 2.0 — PRODUCTION environment example
# Copy to .env.production (or configure these as platform env vars) and adjust.
# NEVER commit the real .env.production to git.
# =============================================================================

FLASK_APP=wsgi.py
FLASK_ENV=production
FLASK_DEBUG=0

# REQUIRED — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-real-random-48+-chars-secret
WTF_CSRF_SECRET_KEY=replace-with-another-random-48+-chars-secret

# REQUIRED — PostgreSQL connection string.
# Render/Railway/Heroku may give you postgres://... — the app auto-rewrites it.
# Recommended modern driver scheme:
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/fitcontrol

# Cookies / session (MUST be True behind HTTPS)
SESSION_COOKIE_SECURE=True
PERMANENT_SESSION_LIFETIME=28800

# Uploads
MAX_CONTENT_LENGTH=16777216

# Rate limit (Redis recommended in production)
RATELIMIT_DEFAULT=200 per hour
RATELIMIT_STORAGE_URI=redis://default:PASSWORD@HOST:6379/0

# Logging — cloud platforms expect stdout
LOG_LEVEL=INFO
LOG_TO_STDOUT=True

# We're behind a reverse proxy (Render/Railway/Fly/Heroku/Nginx)
BEHIND_PROXY=True

# Port is injected by the platform; do not hardcode
# PORT=5000
